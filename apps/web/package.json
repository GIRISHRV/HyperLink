{
  "name": "@hyperlink/web",
  "version": "1.01.000",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium --project=authenticated-chromium --project=setup",
    "test:e2e:firefox": "playwright test --project=firefox --project=authenticated-firefox --project=setup-firefox",
    "test:e2e:webkit": "playwright test --project=webkit --project=authenticated-webkit --project=setup-webkit",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@repo/types": "*",
    "@repo/utils": "*",
    "@sentry/nextjs": "^10.38.0",
    "@serwist/next": "^9.5.6",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "fflate": "^0.8.2",
    "html5-qrcode": "^2.3.8",
    "idb": "^8.0.0",
    "next": "15.5.14",
    "peerjs": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@upstash/redis": "^1.34.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.14",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
