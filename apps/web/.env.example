# ── Supabase ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ── PeerJS Signaling Server ────────────────────────────────────────────
NEXT_PUBLIC_PEER_SERVER_HOST=localhost
NEXT_PUBLIC_PEER_SERVER_PORT=9000
NEXT_PUBLIC_PEER_SERVER_PATH=/myapp

# ── TURN Server (optional — falls back to public OpenRelay if blank) ───
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# ── Redis Rate Limiting (Optional - Production) ──────────────────────────────
# For production-grade distributed rate limiting
# Free tier: https://upstash.com/ (10K requests/day)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry (optional) ─────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
