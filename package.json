{
  "name": "hyperlink",
  "version": "1.01.000",
  "private": true,
  "description": "HyperLink: High-Speed P2P File Engine using WebRTC and IndexedDB",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prebuild": "if [ \"$CI\" = \"true\" ]; then npm ci; fi",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "typecheck": "npx tsc --noEmit -p apps/web/tsconfig.json",
    "test": "npm test --workspace=apps/web && npm test --workspace=apps/signaling && npm run test:e2e --workspace=apps/web",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "test:e2e:chromium": "npm run test:e2e:chromium --workspace=apps/web",
    "test:e2e:firefox": "npm run test:e2e:firefox --workspace=apps/web",
    "test:e2e:webkit": "npm run test:e2e:webkit --workspace=apps/web",
    "test:e2e:ui": "npm run test:e2e:ui --workspace=apps/web",
    "validate": "turbo run lint typecheck test test:e2e build",
    "prepare": "husky || true",
    "db:reset": "bash scripts/reset-db.sh",
    "db:make-admin": "echo 'Run in Supabase SQL Editor: SELECT make_user_admin('\"'your-email@example.com'\"');'"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4",
    "elliptic": "^6.6.1",
    "eslint": "8.57.1",
    "next": "15.1.7",
    "eslint-config-next": "15.1.7"
  },
  "packageManager": "npm@11.11.0"
}
