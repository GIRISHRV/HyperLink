{
  "name": "hyperlink",
  "version": "1.00.000",
  "private": true,
  "description": "HyperLink: High-Speed P2P File Engine using WebRTC and IndexedDB",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prebuild": "if [ \"$CI\" = \"true\" ]; then npm ci; fi",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "test": "npm test --workspace=apps/web",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "test:e2e:ui": "npm run test:e2e:ui --workspace=apps/web"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.5.0"
}
